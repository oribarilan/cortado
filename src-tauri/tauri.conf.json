{
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "Cortado",
  "version": "0.2.0",
  "identifier": "sh.oribi.cortado",
  "plugins": {},
  "app": {
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": false,
        "title": "Cortado",
        "width": 350,
        "height": 400,
        "decorations": false,
        "transparent": true,
        "visible": false
      },
      {
        "label": "main-screen",
        "title": "Cortado",
        "url": "main-screen.html",
        "fullscreen": false,
        "resizable": false,
        "width": 840,
        "height": 480,
        "decorations": false,
        "transparent": true,
        "visible": false
      },
      {
        "label": "settings",
        "title": "Cortado Settings",
        "url": "settings.html",
        "create": false,
        "width": 780,
        "height": 560,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  }
}
